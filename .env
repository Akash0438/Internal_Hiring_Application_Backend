# ──────────────────────────────────────────────────────────────
# .env.rnd  —  R&D / Development environment
# Usage: set APP_ENV=rnd before starting the server
#   Windows : set APP_ENV=rnd && uvicorn app.main:app --reload
#   macOS   : APP_ENV=rnd uvicorn app.main:app --reload
# ──────────────────────────────────────────────────────────────

MONGODB_URL=

# Leave blank to auto-use: interview_platform_rnd
DATABASE_NAME=interview_platform_rnd

JWT_SECRET_KEY=change-me-rnd
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Gmail SMTP — use an App Password (NOT your real Gmail password)
# Setup: https://myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=
FROM_EMAIL=

FRONTEND_URL=http://localhost:5173
ENVIRONMENT=development
